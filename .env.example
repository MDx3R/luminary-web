# API base URL (backend; use URL reachable from the browser)
# e.g. http://localhost:8000 in dev, http://app:8000 when frontend runs in Docker and calls backend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Default model UUID for creating new chats (placeholder until real model selection)
NEXT_PUBLIC_DEFAULT_MODEL_ID=00000000-0000-0000-0000-000000000001
